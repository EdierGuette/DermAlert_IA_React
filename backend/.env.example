# Django Settings
SECRET_KEY=your-secret-key-here-minimum-50-characters
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database Configuration
DB_NAME=your_database_name
DB_USER=your_database_user
DB_PASSWORD=your_database_password
DB_HOST=localhost
DB_PORT=5432

# Email Configuration
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=Your Name <your-email@gmail.com>

# Security (False for development, True for production with HTTPS)
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False

# Project Name
PROJECT_NAME=DermAlert IA

# Logo Icon (puede ser el nombre de un ion-icon o un emoji)
# Opciones sugeridas:
# - medical-outline (icono de cruz médica)
# - shield-half-outline (escudo)
# - heartbeat-outline (latido del corazón)
# - eyedrop-outline (gota)
# - 🩺 (emoji de estetoscopio)
# - 🧬 (emoji de ADN)
LOGO_ICON=medical-outline