# Entrar a la carpeta raíz del proyecto
cd C:\Users\wposs\Documents\IA_REACT

# Crear archivo .gitignore
@"
# ========== BACKEND ==========
# Entorno virtual
venv/
env/
ENV/
__pycache__/
*.pyc
*.pyo
*.pyd

# Base de datos
*.sqlite3
*.db

# Variables de entorno
.env
.env.local
.env.production

# Archivos de Django
staticfiles/
media/
*.log

# Archivos de migraciones (opcional, si quieres subir las migraciones)
# migrations/*.py
# !migrations/__init__.py

# ========== FRONTEND ==========
# Dependencias
node_modules/
.pnp
.pnp.js

# Build
build/
dist/
*.local

# Archivos de entorno
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# ========== ARCHIVOS GRANDES ==========
# Modelo de IA (si es muy grande, >100MB)
*.h5
*.hdf5
*.ckpt
*.pb

# Dataset
*.jpg
*.jpeg
*.png
*.mp4
*.zip
*.tar.gz

# ========== OTROS ==========
coverage/
.nyc_output/
Thumbs.db
"@ | Out-File -FilePath .gitignore -Encoding utf8